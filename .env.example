# ===========================================
# BitByBit Cursá — Environment Variables
# ===========================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local

# Public — App base URL — REQUIRED
# Used for canonical URLs, sitemap, robots.txt, Open Graph, JSON-LD.
# No trailing slash. Throws at boot if unset.
# Production: https://cursa.bitbybit.com.ar
# Local:      http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Database — Neon Postgres — REQUIRED
# Use the appropriate Neon branch for each environment:
#   - Production: main branch
#   - Preview:    dev branch
#   - CI tests:   test branch (configured separately in .env.test)
DATABASE_URL=postgresql://user@localhost:5432/bitbybit_cursa

# Auth — JWT signing secret — REQUIRED in production
# Signs the session cookie used for buyer login (ADR 0007) and admin
# panel access (ADR 0008). In dev/test a deterministic fallback is
# used so the suite and `npm run dev` work without any env setup.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET=change-this-to-a-random-string

# Admin pubkeys — comma-separated hex pubkeys allowed into /panel/*
# Decision in ADR 0008 — env (not DB) so the very first admin can
# sign in before any row exists. Hex format (64 chars), not npub.
# Example: ADMIN_PUBKEYS=abc123...,def456...
ADMIN_PUBKEYS=

# Nostr — server signing key for outgoing DMs — REQUIRED for DM push
# nsec1... format. Used to encrypt + sign NIP-44 DMs to buyers who
# connected a pubkey at checkout, to logged-in buyers, and to
# auto-renewal subscribers. Decision in ADR 0006.
# Never reaches the client.
NOSTR_NSEC=

# Wapu — Lightning <-> ARS rail — REQUIRED for checkout
# Production base: https://be-prod.wapu.app
# Staging base:    https://staging.wapu.app  (test transactions, fake money)
# API contract:    https://github.com/wapu-app/wapu-cli (the only public
#                  source of the API contract today; the official docs
#                  site does not exist yet).
# Auth header is X-API-Key. Get the key from POST /users/api-token after
# authenticating with email + password against POST /users/login.
#
# WAPU_WEBHOOK_SECRET is reserved — Wapu's webhook story is not
# documented in the public CLI repo. May be replaced by polling.
WAPU_API_KEY=
WAPU_WEBHOOK_SECRET=

# Vercel Blob — image upload destination for /panel/ofertas
# https://vercel.com/docs/storage/vercel-blob
# Required when offerings have images. Falls back to a "no upload"
# state in dev if unset.
BLOB_READ_WRITE_TOKEN=

# NWC — Nostr Wallet Connect — OPTIONAL
# Only consulted when settings.features_autorenewal is true.
# Buyers paste their own NWC URL during the auto-renewal flow; this
# env is reserved for the deployment's own NWC connection if needed
# for a future feature. Leave empty in v1.
NWC_CONNECTION_URL=
