# ===========================================
# BitByBit Cursá — Test Environment
# ===========================================
# Copy to .env.test (gitignored) and fill in for integration tests:
#   cp .env.test.example .env.test
#
# Integration tests under tests/integration/ load this file and
# require a real Postgres connection (Neon test branch recommended).
# Tests truncate every table on each run, so DO NOT point this at a
# database that contains real data.

DATABASE_URL=postgresql://user@localhost:5432/bitbybit_cursa_test
AUTH_SECRET=test-secret-deterministic-for-CI
NEXT_PUBLIC_BASE_URL=http://localhost:3000
